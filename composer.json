{
  "name": "roots/wp-config",
  "description": "Fluent configuration management for WordPress",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "roots.dev",
      "email": "team@roots.dev"
    }
  ],
  "autoload": {
    "psr-4": {
      "Roots\\WPConfig\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Roots\\WPConfig\\Tests\\": "tests"
    }
  },
  "require": {
    "php": ">=8.1",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "illuminate/support": "^12.2",
    "laravel/pint": "^1.13",
    "oscarotero/env": "^2.1",
    "pestphp/pest": "^3.0"
  },
  "scripts": {
    "test": "pest",
    "lint": "pint --test",
    "lint:fix": "pint"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
